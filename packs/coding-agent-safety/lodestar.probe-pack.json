{
  "name": "coding-agent-safety",
  "version": "0.1.0",
  "spec_version": "1",
  "source_type": "local",
  "description": "Adversarial probes and online sentinels for the 'wrap a coding agent' story: prompt injection, tool poisoning, and confidence drift across tool calls and sessions, plus the three first-party sentinels that watch the live event stream.",
  "coverage_areas": [
    "prompt_injection",
    "tool_poisoning",
    "cross_tool_manipulation",
    "cross_session_persistence",
    "auto_observation_gate",
    "mcp_proxy",
    "confidence_calibration",
    "low_confidence_action",
    "memory_provenance",
    "anomalous_tool_sequence"
  ],
  "invariants": [
    "injection_defense",
    "no_self_promotion",
    "cross_tool_injection_does_not_promote",
    "cross_session_provenance_survives",
    "miscalibration_flagged_per_class",
    "synthetic_beliefs_excluded_from_calibration",
    "high_trust_action_on_weak_belief_flagged",
    "external_document_belief_steers_decision_flagged",
    "anomalous_tool_sequence_flagged"
  ],
  "probes": [
    {
      "name": "prompt-injection-cross-tool",
      "file": "probes/prompt-injection-cross-tool.ts"
    },
    {
      "name": "tool-poisoning-cross-session",
      "file": "probes/tool-poisoning-cross-session.ts"
    },
    {
      "name": "confidence-drift",
      "file": "probes/confidence-drift.ts"
    }
  ],
  "sentinels": [
    { "id": "low-confidence-action" },
    { "id": "suspicious-memory-origin" },
    { "id": "anomalous-tool-sequence" }
  ]
}
