{
  "name": "lodestar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/adapters/*",
    "packages/memory-firewall/adapters/*",
    "examples/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "bun run typecheck:packages && bun run typecheck:examples",
    "typecheck:packages": "tsc -b",
    "typecheck:examples": "bun run --filter './examples/*' typecheck",
    "test": "bun test",
    "lint": "biome check packages examples research packs",
    "format": "biome format --write packages examples research packs",
    "example:telenotes": "bun run examples/telenotes-governed-dev/index.ts",
    "probe:poison": "bun run packs/lodestar-core/probes/memory-poisoning-basic.ts",
    "probe:chain": "bun run packs/lodestar-core/probes/epistemic-chain-smoke.ts",
    "probe:external": "bun run packs/lodestar-core/probes/external-document-not-normal.ts",
    "probe:quarantine": "bun run packs/lodestar-core/probes/quarantined-not-retrievable.ts",
    "probe:sensitivity": "bun run packs/lodestar-core/probes/sensitivity-ceiling.ts",
    "probe:autoobs": "bun run packs/lodestar-core/probes/auto-observation-gate.ts",
    "probe:guard-import": "bun run packs/lodestar-core/probes/guard-import-no-self-promote.ts",
    "probe:guard-precond": "bun run packs/lodestar-core/probes/guard-precondition-revalidation.ts",
    "probe:guard-contract": "bun run packs/lodestar-core/probes/guard-contract-invariants.ts",
    "probe:contradiction-routing": "bun run packs/lodestar-core/probes/context-policy-contradiction-routing.ts",
    "probe:kernel-context": "bun run packs/lodestar-core/probes/kernel-context-propagation.ts",
    "probe:singlewriter": "bun run packs/lodestar-core/probes/event-log-single-writer.ts",
    "probe:mcp-roundtrip": "bun run packs/lodestar-core/probes/mcp-proxy-roundtrip.ts",
    "probe:mcp-injection": "bun run packs/lodestar-core/probes/mcp-proxy-injection-defense.ts",
    "probe:reflection-retrieval": "bun run packs/lodestar-core/probes/reflection-cannot-promote-to-normal-alone.ts",
    "probe:reflection-cascade": "bun run packs/lodestar-core/probes/contradicted-belief-flags-dependent-decisions.ts",
    "probe:canonical-hash": "bun run packs/lodestar-core/probes/event-log-canonical-hash.ts",
    "probes:all": "bun run probe:poison && bun run probe:chain && bun run probe:external && bun run probe:quarantine && bun run probe:sensitivity && bun run probe:autoobs && bun run probe:guard-import && bun run probe:guard-precond && bun run probe:guard-contract && bun run probe:contradiction-routing && bun run probe:kernel-context && bun run probe:singlewriter && bun run probe:mcp-roundtrip && bun run probe:mcp-injection && bun run probe:reflection-retrieval && bun run probe:reflection-cascade && bun run probe:canonical-hash",
    "lodestar": "bun run packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "latest",
    "typescript": "5.6.3",
    "zod": "^3.23.8",
    "@qmilab/lodestar-core": "workspace:*",
    "@qmilab/lodestar-event-log": "workspace:*",
    "@qmilab/lodestar-action-kernel": "workspace:*",
    "@qmilab/lodestar-memory-firewall": "workspace:*",
    "@qmilab/lodestar-cognitive-core": "workspace:*",
    "@qmilab/lodestar-adapter-filesystem": "workspace:*",
    "@qmilab/lodestar-adapter-git": "workspace:*",
    "@qmilab/lodestar-trace": "workspace:*",
    "@qmilab/lodestar-harness": "workspace:*",
    "@qmilab/lodestar-guard": "workspace:*",
    "@qmilab/lodestar-guard-mcp": "workspace:*",
    "@qmilab/lodestar-memory-firewall-mem0": "workspace:*",
    "@qmilab/lodestar-memory-firewall-letta": "workspace:*",
    "@qmilab/lodestar-memory-firewall-zep": "workspace:*"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
