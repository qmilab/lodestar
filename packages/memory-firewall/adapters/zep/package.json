    "directory": "packages/memory-firewall/adapters/zep"
  },
  "bugs": {
    "url": "https://github.com/qmilab/lodestar/issues"
  },
  "keywords": [
    "ai-agents",
    "trust",
    "lodestar",
    "memory-firewall",
    "zep",
    "memory-import",
    "adapter"
  ],
  "type": "module",
  "main": "./dist/index.js",
