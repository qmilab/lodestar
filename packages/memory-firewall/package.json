{
  "name": "@qmilab/lodestar-memory-firewall",
  "version": "0.4.0",
  "description": "Lifecycle gates for claims and beliefs — four orthogonal axes (truth, retrieval, security, freshness) with per-axis transition rules. Part of Lodestar, the trust layer for AI agents.",
  "license": "Apache-2.0",
  "author": "QMI Lab <hello@qmilab.com>",
  "homepage": "https://qmilab.com/lodestar",
  "repository": {
    "type": "git",
    "url": "https://github.com/qmilab/lodestar.git",
    "directory": "packages/memory-firewall"
  },
  "bugs": {
    "url": "https://github.com/qmilab/lodestar/issues"
  },
  "keywords": [
    "ai-agents",
    "trust",
    "lodestar",
    "memory-firewall",
    "belief",
    "governance",
    "lifecycle",
    "memory-poisoning"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./postgres": {
      "bun": "./src/stores/postgres.ts",
      "types": "./dist/stores/postgres.d.ts",
      "import": "./dist/stores/postgres.js",
      "default": "./dist/stores/postgres.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@qmilab/lodestar-core": "workspace:*",
    "@qmilab/lodestar-event-log": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
