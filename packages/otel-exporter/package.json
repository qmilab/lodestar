{
  "name": "@qmilab/lodestar-otel-exporter",
  "version": "0.2.0",
  "description": "Project the Lodestar event log into OpenTelemetry GenAI spans and export them over OTLP/HTTP — pair the epistemic chain with Langfuse, Phoenix, Jaeger, or Tempo. Part of Lodestar, the trust layer for AI agents.",
  "license": "Apache-2.0",
  "author": "QMI Lab <hello@qmilab.com>",
  "homepage": "https://qmilab.com/lodestar",
  "repository": {
    "type": "git",
    "url": "https://github.com/qmilab/lodestar.git",
    "directory": "packages/otel-exporter"
  },
  "bugs": {
    "url": "https://github.com/qmilab/lodestar/issues"
  },
  "keywords": [
    "ai-agents",
    "trust",
    "lodestar",
    "opentelemetry",
    "otel",
    "otlp",
    "gen-ai",
    "observability",
    "epistemic-chain"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@qmilab/lodestar-core": "workspace:*",
    "@qmilab/lodestar-trace": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
