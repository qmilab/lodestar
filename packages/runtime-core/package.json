{
  "name": "@qmilab/lodestar-runtime-core",
  "version": "0.3.0",
  "description": "The language-agnostic governance-gate sidecar — govern a non-MCP agent runtime (LangGraph, CrewAI, AutoGen) by remoting each native tool call through the Action Kernel over a thin NDJSON-RPC seam. The reusable spine of Lodestar's runtime-adapter epic.",
  "license": "Apache-2.0",
  "author": "QMI Lab <hello@qmilab.com>",
  "homepage": "https://qmilab.com/lodestar",
  "repository": {
    "type": "git",
    "url": "https://github.com/qmilab/lodestar.git",
    "directory": "packages/runtime-core"
  },
  "bugs": {
    "url": "https://github.com/qmilab/lodestar/issues"
  },
  "keywords": [
    "ai-agents",
    "trust",
    "lodestar",
    "governance",
    "runtime-adapter",
    "langgraph",
    "rpc",
    "epistemic-chain"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@qmilab/lodestar-core": "workspace:*",
    "@qmilab/lodestar-event-log": "workspace:*",
    "@qmilab/lodestar-action-kernel": "workspace:*",
    "@qmilab/lodestar-policy-kernel": "workspace:*",
    "@qmilab/lodestar-memory-firewall": "workspace:*",
    "@qmilab/lodestar-cognitive-core": "workspace:*",
    "@qmilab/lodestar-guard": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
