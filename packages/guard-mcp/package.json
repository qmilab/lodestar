{
  "name": "@qmilab/lodestar-guard-mcp",
  "version": "0.2.0",
  "description": "MCP proxy mode for Lodestar Guard — wrap any MCP-speaking agent (Claude Code, Cursor, Aider) so every tool call passes through the Action Kernel and every result through the Cognitive Core. Part of Lodestar, the trust layer for AI agents.",
  "license": "Apache-2.0",
  "author": "QMI Lab <hello@qmilab.com>",
  "homepage": "https://qmilab.com/lodestar",
  "repository": {
    "type": "git",
    "url": "https://github.com/qmilab/lodestar.git",
    "directory": "packages/guard-mcp"
  },
  "bugs": {
    "url": "https://github.com/qmilab/lodestar/issues"
  },
  "keywords": [
    "ai-agents",
    "trust",
    "lodestar",
    "guard",
    "mcp",
    "model-context-protocol",
    "proxy",
    "audit-trail"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "spike": "bun run src/bin/spike.ts"
  },
  "dependencies": {
    "@qmilab/lodestar-core": "workspace:*",
    "@qmilab/lodestar-event-log": "workspace:*",
    "@qmilab/lodestar-action-kernel": "workspace:*",
    "@qmilab/lodestar-memory-firewall": "workspace:*",
    "@qmilab/lodestar-cognitive-core": "workspace:*",
    "@qmilab/lodestar-guard": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@qmilab/lodestar-harness": "workspace:*",
    "typescript": "5.6.3"
  }
}
